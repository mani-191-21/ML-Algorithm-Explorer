# Environment Configuration
ENVIRONMENT=development
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO

# Model Configuration
MODEL_LOAD_TIMEOUT=30

# Feature Flags
ENABLE_MODEL_COMPARISON=true
ENABLE_CHART_DATA=true
